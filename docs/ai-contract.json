{
  "$schema_note": "Contratto machine-readable per il supervisore AI. Path relativi alla root repo.",
  "project": "gsdcampus-autoplay",
  "version": "1.2.0",
  "package_version": "1.1.0",
  "entrypoints": {
    "autoplay": "src/autoplay.js",
    "start": "start.sh",
    "stop": "stop.sh",
    "status": "status.sh",
    "setup": "scripts/setup.sh",
    "install": "install.sh",
    "ai_budget": "src/lib/ai-budget.js",
    "ai_proxy": "scripts/lib/ollama-cloud-proxy.js",
    "claude_quiz_runner": "scripts/lib/claude-quiz-runner.js",
    "claude_batch": "scripts/run-claude-quiz-batch.sh"
  },
  "paths": {
    "config": "config.json",
    "known_answers_trusted": "data/known_answers.json",
    "known_answers_public": "data/known_answers_public.json",
    "members_db": "data/members.db",
    "accounts_dir": "data/accounts",
    "status": "logs/status.json",
    "autoplay_log": "logs/autoplay.log",
    "ai_todo": "logs/ai_todo.json",
    "metrics": "logs/metrics.jsonl",
    "dashboard": "data/dashboard.json",
    "roadmap": "docs/ROADMAP-V2.md",
    "security": "docs/SECURITY-MEMBERS.md",
    "runbook_keys": "docs/RUNBOOK-KEYS.md"
  },
  "ai_supervisor": {
    "client": "claude-on-demand",
    "provider": "ollama-budget-anthropic",
    "endpoint": "Claude Code one-shot → proxy budget 127.0.0.1:11435 → daemon Ollama 127.0.0.1:11434 → Cloud",
    "authentication": "ollama signin via browser; token proxy casuale solo in variabili ambiente del batch",
    "lifecycle": "nessun processo AI persistente; anche setup/doctor non eseguono CLI AI senza lavoro; daemon/proxy/Claude partono soltanto con openQuizRequests > 0 e vengono chiusi a fine batch",
    "gate": "buildAiTodo unifica e deduplica ai_quiz_request + need_answer per tutti gli account; openQuizRequests > 0 e l'unico gate AI",
    "payload": "solo id effimero, domanda, opzioni e guess; mai CF, URL, token, cookie o contesti account",
    "output": "JSON schema; risposta accettata solo con confidence >= 0.7 e match esatto di un'opzione quando presente",
    "local_proxy": "127.0.0.1:11435 (temporaneo)",
    "budget_file": "data/ai_usage.json (metadata only, gitignored)",
    "limits": { "weekly": 400, "daily": 80, "perMinute": 8, "minIntervalMs": 1500, "maxConcurrent": 1, "maxPerBatch": 8 },
    "quiz_default": "useOllamaForQuiz=false; AI is invoked only for a new supervisor handoff fingerprint"
  },
  "account_files": {
    "course_state": "data/accounts/<CF>/course_state.json",
    "ai_quiz_request": "data/accounts/<CF>/ai_quiz_request.json",
    "need_answer": "data/accounts/<CF>/need_answer.json",
    "storage_state": "data/accounts/<CF>/storage_state.json"
  },
  "hardening": {
    "course_state": "assessment ledger per questionario; quizAttempts aumenta solo dopo Conferma; protectedSuspensions conta i gate senza tentativo",
    "handoff_schema": 2,
    "ai_todo_schema": 2,
    "phases": ["awaiting_ai", "complete", "off_hours", "preflight_failed"],
    "notification_policy": "fingerprint per account/corso/questionario; throttle lungo per lavoro invariato",
    "runtime_lock": "directory atomica + PID + token command-line; rifiuta PID recycling",
    "course_state_backup": "snapshot SHA-256 per-account prima di reopen/reset; restore same-account only",
    "answer_bank_integrity": "normalizzazione Unicode, conflitti bloccanti, hash canonico locale/main",
    "selector_preflight": "gate offline prima di ogni sessione browser",
    "ai_fingerprint": "un solo batch per workFingerprint; errori in cooldown e output invalidi lasciano intatto l'handoff",
    "ai_routes": ["POST /v1/messages", "POST /v1/messages/count_tokens"],
    "ai_tools": ["WebSearch", "WebFetch"]
  },
  "commands": {
    "status": "./status.sh",
    "status_live_autologin": "./status.sh --check",
    "start_respect_hours": "./start.sh",
    "start_ignore_hours": "./start.sh --ignore-hours",
    "stop": "./stop.sh",
    "harvest_all": "node scripts/harvest-answers.js --all",
    "harvest_census": "node scripts/harvest-answers.js --census",
    "harvest_reconcile_reset": "node scripts/harvest-answers.js --reconcile --reset --yes",
    "answers_resolve": "node scripts/lib/answers-cli.js resolve \"domanda\" \"risposta\"",
    "answers_stats": "node scripts/lib/answers-cli.js stats",
    "publish_answers": "./scripts/publish-answers.sh",
    "members_active": "node scripts/lib/members-cli.js active",
    "members_set_active": "node scripts/lib/members-cli.js set-active <CF>",
    "dashboard_list": "node scripts/lib/dashboard-cli.js list",
    "dashboard_csv": "node scripts/lib/dashboard-cli.js csv",
    "metrics_summary": "node scripts/lib/metrics-cli.js summary",
    "metrics_share": "node scripts/lib/metrics-cli.js share",
    "harvest_night": "./scripts/harvest-night.sh",
    "weekly_report": "node scripts/lib/weekly-report-cli.js [--save] [--hours 168]",
    "answers_lag": "node scripts/lib/answers-cli.js lag",
    "answers_audit": "node scripts/lib/answers-cli.js audit [--fix]",
    "answers_verify": "node scripts/lib/answers-cli.js verify [--remote]",
    "ai_budget": "node scripts/lib/ai-budget-cli.js [--json]",
    "ai_batch": "./scripts/run-claude-quiz-batch.sh [--force]",
    "course_state_backup_list": "node scripts/lib/course-state-backup-cli.js list",
    "course_state_backup_restore": "node scripts/lib/course-state-backup-cli.js restore <name> --yes",
    "members_queue_list": "node scripts/lib/members-cli.js queue list",
    "members_queue_set": "node scripts/lib/members-cli.js queue set CF1 CF2",
    "healthcheck": "node scripts/lib/healthcheck-cli.js",
    "issue_draft": "node scripts/lib/issue-report.js draft \"<phase>\" [\"reason\"]",
    "issue_send": "node scripts/lib/issue-report.js send",
    "dev_check": "zsh ./scripts/dev-check.sh",
    "test": "npm test"
  },
  "exit_codes": {
    "0": "clean exit (fine turno, all done/need_help/awaiting_ai)",
    "1": "fatal / tentativi esauriti",
    "2": "need_help (quiz sospeso / AI request)",
    "3": "autologin_invalid",
    "4": "session_unstable o post_login_blocked (cooldown, non crash)"
  },
  "ai_batch_exit_codes": {
    "0": "risposte valide applicate e share fleet completato/noop",
    "20": "nessun lavoro AI",
    "21": "fingerprint gia elaborato",
    "22": "output strutturato non valido",
    "23": "errore Claude; retryAfter 30 minuti",
    "24": "componenti o login AI non pronti",
    "25": "risposte locali salve ma share fleet pending"
  },
  "config_keys": {
    "autologinUrl": "required",
    "codice_fiscale": "preferred",
    "workSchedule": "days + shifts",
    "ollamaModel": "string",
    "aiSupervisorClient": "claude-on-demand",
    "ollamaLocalEndpoint": "http://127.0.0.1:11434",
    "aiCloudProxyPort": "number 1024-65535",
    "aiWeeklyRequestLimit": "number capped at 500",
    "aiDailyRequestLimit": "number capped at 100",
    "aiPerMinuteRequestLimit": "number capped at 10",
    "aiMinRequestIntervalMs": "number milliseconds",
    "aiMaxConcurrentRequests": "1",
    "aiClaudeMaxRequestsPerBatch": "number default 8 hard-capped at 8; config may only lower it",
    "aiClaudeTimeoutMs": "number default 900000 capped at 1800000",
    "useOllamaForQuiz": "false; autoplay never invokes Ollama directly",
    "memberQueue": "string[] CF optional",
    "memberQueueIndex": "number optional",
    "shareMetrics": "boolean opt-in",
    "storeTag": "anonymous store label optional",
    "sessionUnstableCooldownMin": "number minutes default 30",
    "notifications": "boolean default true",
    "autoShareAnswers": "boolean default true (resolve → Worker)",
    "autoUpdate": "boolean default true",
    "browserChannel": "chrome | chromium | auto | null"
  },
  "limits": {
    "do_not_edit": ["src/**", "scripts/**", "*.sh"],
    "may_edit": ["config.json"],
    "never_delete": [
      "data/known_answers.json",
      "data/known_answers_public.json",
      "data/members.db",
      "data/accounts/**"
    ]
  }
}
